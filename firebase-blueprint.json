{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A chat message",
      "type": "object",
      "properties": {
        "user": {
          "type": "string",
          "description": "The user's display name"
        },
        "text": {
          "type": "string",
          "description": "The message content"
        },
        "timestamp": {
          "type": "number",
          "description": "The time the message was sent"
        },
        "uid": {
          "type": "string",
          "description": "The user's unique ID"
        },
        "reactions": {
          "type": "object",
          "description": "Map of user UIDs to their emoji reaction"
        }
      },
      "required": ["user", "text", "timestamp", "uid"]
    },
    "User": {
      "title": "User",
      "description": "A user profile",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "The user's chosen username"
        },
        "email": {
          "type": "string",
          "description": "The user's email address"
        },
        "approved": {
          "type": "boolean",
          "description": "Whether the user is approved by an admin"
        },
        "role": {
          "type": "string",
          "description": "The user's role (admin or user)"
        },
        "createdAt": {
          "type": "number",
          "description": "When the user signed up"
        },
        "points": {
          "type": "number",
          "description": "User points earned from messages and games"
        },
        "messagesSent": {
          "type": "number",
          "description": "Total messages sent by user"
        },
        "gamesPlayed": {
          "type": "number",
          "description": "Total games played by user"
        },
        "bio": {
          "type": "string",
          "description": "User bio/status"
        },
        "banned": {
          "type": "boolean",
          "description": "Whether user is banned"
        },
        "banReason": {
          "type": "string",
          "description": "Reason for ban"
        },
        "muted": {
          "type": "boolean",
          "description": "Whether user is muted"
        },
        "mutedUntil": {
          "type": "number",
          "description": "Timestamp when mute expires"
        },
        "favoriteGame": {
          "type": "string",
          "description": "User's favorite game to display on profile"
        },
        "totalPlaytime": {
          "type": "number",
          "description": "Total playtime in minutes"
        },
        "status": {
          "type": "string",
          "description": "User status (Online, Away, Do Not Disturb, Gaming, Idle)"
        },
        "profileColor": {
          "type": "string",
          "description": "Profile accent color hex code"
        }
      },
      "required": ["username", "email", "approved", "role", "createdAt"]
    },
    "FriendRequest": {
      "title": "FriendRequest",
      "description": "A request to be friends",
      "type": "object",
      "properties": {
        "fromId": { "type": "string" },
        "fromName": { "type": "string" },
        "toId": { "type": "string" },
        "toName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted"] },
        "timestamp": { "type": "number" }
      },
      "required": ["fromId", "fromName", "toId", "toName", "status", "timestamp"]
    },
    "DirectMessage": {
      "title": "DirectMessage",
      "description": "A private message between two users",
      "type": "object",
      "properties": {
        "participants": { "type": "array", "items": { "type": "string" } },
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "timestamp": { "type": "number" },
        "channelId": { "type": "string" }
      },
      "required": ["participants", "text", "senderId", "senderName", "timestamp", "channelId"]
    },
    "GameSuggestion": {
      "title": "GameSuggestion",
      "description": "A community game suggestion",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Suggested game title" },
        "url": { "type": "string", "description": "Optional game URL" },
        "category": { "type": "string", "description": "Game category" },
        "suggestedBy": { "type": "string", "description": "UID of suggester" },
        "suggestedByName": { "type": "string", "description": "Username of suggester" },
        "votes": { "type": "number", "description": "Vote count" },
        "voters": { "type": "object", "description": "Map of voter UIDs to vote direction" },
        "timestamp": { "type": "number", "description": "When suggested" },
        "status": { "type": "string", "enum": ["pending", "approved"], "description": "Approval status" }
      },
      "required": ["title", "category", "suggestedBy", "suggestedByName", "votes", "timestamp", "status"]
    }
  },
  "firestore": {
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages collection"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles collection"
    },
    "/friend_requests/{requestId}": {
      "schema": "FriendRequest",
      "description": "Friend requests collection"
    },
    "/direct_messages/{messageId}": {
      "schema": "DirectMessage",
      "description": "Direct messages collection"
    },
    "/game_suggestions/{suggestionId}": {
      "schema": "GameSuggestion",
      "description": "Community game suggestions collection"
    }
  }
}
