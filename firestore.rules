rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: messages
    // Document ID: auto-generated
    // Fields:
    //   - user: string (required, 1-50 chars) - Display name of the sender
    //   - text: string (required, 1-1000 chars) - Message content
    //   - timestamp: number (required) - Milliseconds since epoch
    //   - uid: string (required) - UID of the sender
    //
    // Collection: users
    // Document ID: user UID
    // Fields:
    //   - username: string (required)
    //   - email: string (required)
    //   - approved: boolean (required)
    //   - role: string (required, 'admin' or 'user')
    //   - createdAt: number (required)
    //
    // Collection: dms
    // Document ID: auto-generated
    // Fields:
    //   - from: string (required) - UID of the sender
    //   - to: string (required) - UID of the recipient
    //   - participants: list (required) - Array of [from, to] sorted
    //   - text: string (required, 1-1000 chars) - Message content
    //   - timestamp: number (required) - Milliseconds since epoch
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (userExists() && getUserData().role == 'admin') ||
          (request.auth.token.email == "kyler@nexus.games") ||
          (request.auth.token.email == "KylerTheCoolCat@gmail.com")
        );
    }

    function isApproved() {
      return isAuthenticated() && 
        (isAdmin() || (userExists() && getUserData().approved == true && getUserData().get('banned', false) == false));
    }

    function isMuted() {
      return userExists() && getUserData().get('muted', false) == true && 
             (getUserData().get('muteExpires', 0) == 0 || getUserData().get('muteExpires', 0) > request.time.toMillis());
    }

    function isValidMessage(data) {
      return data.user is string && data.user.size() > 0 && data.user.size() < 50 &&
             (data.get('text', '') is string && data.get('text', '').size() <= 1000) &&
             (data.get('gif', '') is string && data.get('gif', '').size() <= 500) &&
             data.timestamp is number &&
             data.uid is string &&
             (data.uid == request.auth.uid || isAdmin());
    }

    function isValidUser(data) {
      return data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.email is string && data.email.size() < 100 &&
             data.approved is bool &&
             data.role in ['admin', 'user'] &&
             data.createdAt is number &&
             (data.get('bio', '') is string && data.get('bio', '').size() <= 500) &&
             (data.get('points', 0) is number) &&
             (data.get('banned', false) is bool) &&
             (data.get('muted', false) is bool) &&
             (data.get('muteExpires', 0) is number) &&
             (data.get('wishlist', []) is list) &&
             (data.get('totalPlaytime', 0) is number) &&
             (data.get('gamesPlayed', 0) is number) &&
             (data.get('messagesSent', 0) is number) &&
             (data.get('favoriteGame', '') is string) &&
             (data.get('badges', []) is list) &&
             (data.get('level', 1) is number);
    }

    function isValidUpdateLog(data) {
      return data.version is string &&
             data.date is string &&
             data.content is string &&
             data.timestamp is number;
    }

    function isValidRating(data) {
      return data.uid == request.auth.uid &&
             data.gameTitle is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.timestamp is number;
    }

    function isValidSuggestion(data) {
      return data.uid == request.auth.uid &&
             data.username is string &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.timestamp is number;
    }

    function isValidFriendRequest(data) {
      return data.fromId == request.auth.uid &&
             data.fromName is string &&
             data.toId is string &&
             data.toName is string &&
             data.status in ['pending', 'accepted'] &&
             data.timestamp is number;
    }

    function isValidDirectMessage(data) {
      return data.from == request.auth.uid &&
             data.to is string &&
             data.participants is list && data.participants.size() == 2 &&
             request.auth.uid in data.participants &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.timestamp is number &&
             !isMuted();
    }

    match /messages/{messageId} {
      allow read: if isApproved();
      allow create: if isApproved() && isValidMessage(request.resource.data) && !isMuted();
      allow update: if (isAdmin() && isValidMessage(request.resource.data)) || 
                      (isAuthenticated() && isApproved() && !isMuted() && 
                       request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']));
      allow delete: if isAuthenticated() && (isAdmin() || (resource.data.uid == request.auth.uid && (request.time.toMillis() - resource.data.timestamp < 10000)));
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && 
                      isValidUser(request.resource.data) && 
                      (
                        (request.resource.data.approved == false && request.resource.data.role == 'user') ||
                        (request.auth.token.email == "kyler@nexus.games" && request.resource.data.role == 'admin' && request.resource.data.approved == true)
                      );
      allow update: if isAuthenticated() && (
        (isOwner(userId) && isValidUser(request.resource.data) && 
         request.resource.data.approved == resource.data.approved && 
         request.resource.data.role == resource.data.role &&
         request.resource.data.get('banned', false) == resource.data.get('banned', false) &&
         request.resource.data.get('muted', false) == resource.data.get('muted', false) &&
         request.resource.data.get('muteExpires', 0) == resource.data.get('muteExpires', 0) &&
         request.resource.data.get('badges', []) == resource.data.get('badges', []) &&
         request.resource.data.get('points', 0) == resource.data.get('points', 0) &&
         request.resource.data.get('level', 1) == resource.data.get('level', 1)
        ) ||
        (isAdmin() && isValidUser(request.resource.data))
      );
      allow delete: if isAdmin();
    }

    match /friend_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow create: if isAuthenticated() && isValidFriendRequest(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.toId == request.auth.uid) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
                      request.resource.data.status == 'accepted';
      allow delete: if isAuthenticated() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
    }

    match /dms/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants);
      allow create: if isAuthenticated() && isValidDirectMessage(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.from == request.auth.uid);
    }

    match /suggestions/{suggestionId} {
      allow read: if isApproved();
      allow create: if isApproved() && isValidSuggestion(request.resource.data);
      allow delete: if isAdmin();
    }

    match /ratings/{ratingId} {
      allow read: if isApproved();
      allow create: if isApproved() && isValidRating(request.resource.data);
      allow update: if isApproved() && resource.data.uid == request.auth.uid && isValidRating(request.resource.data);
      allow delete: if isApproved() && resource.data.uid == request.auth.uid;
    }

    match /update_logs/{logId} {
      allow read: if true;
      allow write: if isAdmin() && isValidUpdateLog(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      // Everyone approved can read settings so featured overrides/thumbnails propagate server-wide.
      allow read: if isApproved();

      // Allow approved users to update shared settings docs (featured override / thumbnails).
      allow create, update, delete: if isApproved();
    }
  }
}
