rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: messages
    // Document ID: auto-generated
    // Fields:
    //   - user: string (required, 1-50 chars) - Display name of the sender
    //   - text: string (required, 1-1000 chars) - Message content
    //   - timestamp: number (required) - Milliseconds since epoch
    //   - uid: string (required) - UID of the sender
    //
    // Collection: users
    // Document ID: user UID
    // Fields:
    //   - username: string (required)
    //   - email: string (required)
    //   - approved: boolean (required)
    //   - role: string (required, 'admin' or 'user')
    //   - createdAt: number (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (userExists() && getUserData().role == 'admin') ||
          (request.auth.token.email == "kyler@nexus.games")
        );
    }

    function isApproved() {
      return isAuthenticated() && 
        (isAdmin() || (userExists() && getUserData().approved == true && getUserData().get('banned', false) == false));
    }

    function isMuted() {
      return userExists() && getUserData().get('muted', false) == true && 
             (getUserData().get('muteExpires', 0) == 0 || getUserData().get('muteExpires', 0) > request.time.toMillis());
    }

    function isValidMessage(data) {
      return data.user is string && data.user.size() > 0 && data.user.size() < 50 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.timestamp is number &&
             data.uid == request.auth.uid &&
             !isMuted();
    }

    function isValidUser(data) {
      return data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.email is string && data.email.size() < 100 &&
             data.approved is bool &&
             data.role in ['admin', 'user'] &&
             data.createdAt is number &&
             (data.get('bio', '') is string && data.get('bio', '').size() < 500) &&
             (data.get('points', 0) is number) &&
             (data.get('banned', false) is bool) &&
             (data.get('muted', false) is bool) &&
             (data.get('muteExpires', 0) is number) &&
             (data.get('wishlist', []) is list);
    }

    function isValidSuggestion(data) {
      return data.uid == request.auth.uid &&
             data.username is string &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.timestamp is number;
    }

    function isValidFriendRequest(data) {
      return data.fromId == request.auth.uid &&
             data.fromName is string &&
             data.toId is string &&
             data.toName is string &&
             data.status in ['pending', 'accepted'] &&
             data.timestamp is number;
    }

    function isValidDirectMessage(data) {
      return request.auth.uid in data.participants &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.senderId == request.auth.uid &&
             data.senderName is string &&
             data.timestamp is number &&
             data.channelId is string &&
             !isMuted();
    }

    match /messages/{messageId} {
      allow read: if isApproved();
      allow create: if isApproved() && isValidMessage(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && 
                      isValidUser(request.resource.data) && 
                      (
                        (request.resource.data.approved == false && request.resource.data.role == 'user') ||
                        (request.auth.token.email == "kyler@nexus.games" && request.resource.data.role == 'admin' && request.resource.data.approved == true)
                      );
      allow update: if isAuthenticated() && (
        (isOwner(userId) && isValidUser(request.resource.data) && 
         request.resource.data.approved == resource.data.approved && 
         request.resource.data.role == resource.data.role &&
         request.resource.data.get('banned', false) == resource.data.get('banned', false) &&
         request.resource.data.get('muted', false) == resource.data.get('muted', false) &&
         request.resource.data.get('muteExpires', 0) == resource.data.get('muteExpires', 0)
        ) ||
        (isAdmin() && isValidUser(request.resource.data))
      );
      allow delete: if isAdmin();
    }

    match /friend_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow create: if isAuthenticated() && isValidFriendRequest(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.toId == request.auth.uid) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
                      request.resource.data.status == 'accepted';
      allow delete: if isAuthenticated() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
    }

    match /direct_messages/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants);
      allow create: if isAuthenticated() && isValidDirectMessage(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.senderId == request.auth.uid);
    }

    match /suggestions/{suggestionId} {
      allow read: if isApproved();
      allow create: if isApproved() && isValidSuggestion(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
