rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: messages
    // Document ID: auto-generated
    // Fields:
    //   - user: string (required, 1-50 chars) - Display name of the sender
    //   - text: string (required, 1-1000 chars) - Message content
    //   - timestamp: number (required) - Milliseconds since epoch
    //   - uid: string (required) - UID of the sender
    //   - reactions: map (optional) - Map of uid -> emoji for message reactions
    //
    // Collection: users
    // Document ID: user UID
    // Fields:
    //   - username: string (required)
    //   - email: string (required)
    //   - approved: boolean (required)
    //   - role: string (required, 'admin' or 'user')
    //   - createdAt: number (required)
    //   - favoriteGame: string (optional) - User's favorite game
    //   - totalPlaytime: number (optional) - Total playtime in minutes
    //   - status: string (optional) - User status (Online, Away, etc.)
    //   - profileColor: string (optional) - Profile color hex
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (userExists() && getUserData().role == 'admin') ||
          (request.auth.token.email == "kyler@nexus.games")
        );
    }

    function isApproved() {
      return isAuthenticated() && 
        (isAdmin() || (userExists() && getUserData().approved == true));
    }

    function isValidMessage(data) {
      return data.user is string && data.user.size() > 0 && data.user.size() < 50 &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.timestamp is number &&
             data.uid == request.auth.uid;
    }

    function isValidUser(data) {
      return data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.email is string && data.email.size() < 100 &&
             data.approved is bool &&
             data.role in ['admin', 'user'] &&
             data.createdAt is number;
    }

    function isValidGameSuggestion(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.category is string &&
             data.suggestedBy == request.auth.uid &&
             data.suggestedByName is string &&
             data.votes is number &&
             data.timestamp is number &&
             data.status in ['pending', 'approved'];
    }

    function isValidFriendRequest(data) {
      return data.fromId == request.auth.uid &&
             data.fromName is string &&
             data.toId is string &&
             data.toName is string &&
             data.status in ['pending', 'accepted'] &&
             data.timestamp is number;
    }

    function isValidDirectMessage(data) {
      return request.auth.uid in data.participants &&
             data.text is string && data.text.size() > 0 && data.text.size() < 1000 &&
             data.senderId == request.auth.uid &&
             data.senderName is string &&
             data.timestamp is number &&
             data.channelId is string;
    }

    match /messages/{messageId} {
      allow read: if isApproved();
      allow create: if isApproved() && isValidMessage(request.resource.data);
      allow update: if isApproved() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']) &&
        request.resource.data.reactions.diff(resource.data.get('reactions', {})).affectedKeys().hasOnly([request.auth.uid]);
      allow delete: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && 
                      isValidUser(request.resource.data) && 
                      (
                        (request.resource.data.approved == false && request.resource.data.role == 'user') ||
                        (request.auth.token.email == "kyler@nexus.games" && request.resource.data.role == 'admin' && request.resource.data.approved == true)
                      );
      allow update: if isAuthenticated() && (
        (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.approved == resource.data.approved && request.resource.data.role == resource.data.role && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['username', 'email', 'approved', 'role', 'createdAt', 'bio', 'favoriteGame', 'totalPlaytime', 'status', 'profileColor', 'points', 'messagesSent', 'gamesPlayed']) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['points']) || request.resource.data.points <= resource.data.points + 5) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['messagesSent']) || request.resource.data.messagesSent == resource.data.messagesSent + 1) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['gamesPlayed']) || request.resource.data.gamesPlayed == resource.data.gamesPlayed + 1)) ||
        (isAdmin() && isValidUser(request.resource.data))
      );
    }

    match /friend_requests/{requestId} {
      allow read: if isAuthenticated() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
      allow create: if isAuthenticated() && isValidFriendRequest(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.toId == request.auth.uid) && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
                      request.resource.data.status == 'accepted';
      allow delete: if isAuthenticated() && (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid);
    }

    match /direct_messages/{messageId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants);
      allow create: if isAuthenticated() && isValidDirectMessage(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.senderId == request.auth.uid);
    }

    match /game_suggestions/{suggestionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidGameSuggestion(request.resource.data);
      allow update: if isAuthenticated() && (
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes', 'voters']) &&
         (request.resource.data.votes == resource.data.votes + 1 || request.resource.data.votes == resource.data.votes - 1) &&
         request.resource.data.voters.diff(resource.data.get('voters', {})).affectedKeys().hasOnly([request.auth.uid])) ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }
  }
}
